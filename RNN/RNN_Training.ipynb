   "source": [
    "encoded_docs = []\n",
    "\n",
    "for doc in corpus:\n",
    "    encoded_doc = []\n",
    "    for word in doc:\n",
    "        if word in word_to_idx:\n",
    "            encoded_doc.append(word_to_idx[word])\n",
    "        else:\n",
    "            encoded_doc.append(word_to_idx['<UNK>'])\n",
    "    encoded_docs.append(encoded_doc)\n",
    "\n",
    "print(encoded_docs[:2])"
   ]
