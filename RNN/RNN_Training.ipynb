     "text": [
      "[['right', 'way', 'handl', 'sever', 'head', 'injuri'], ['best', 'way', 'keep', 'crimin', 'element', 'workplac'], ['tell', 'chronic', 'headach', 'sign', 'brain', 'tumor']]\n"
